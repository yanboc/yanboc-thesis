\@writefile{lof}{\contentsline {figure}{\numberline {4.6}{\ignorespaces Testing the under-parameterized setting with $C = {\rm  {int}}(0.8P)$. {\color  {red} By comparing to \ref {fig-synthesized-experiment-results}, this set of experimental results implies that slight over-parameterization (i.e., $C = {\rm  {int}}(1.2P)$)could help the model better reconstruct all types of inputs. Here, we primarily compare the magnitudes of $P$ and $C$. Specifically, the scenario where the ratio $C/P>1$ is referred to as \textit  {over-parameterized}, while the converse (i.e., $C/P<1$) is defined as \textit  {under-parameterized}.} }}{60}{figure.caption.16}\protected@file@percent }
\newlabel{fig-synthesized-experiment-results-under-parameterized}{{4.6}{60}{Testing the under-parameterized setting with $C = {\rm {int}}(0.8P)$. {\color {red} By comparing to \ref {fig-synthesized-experiment-results}, this set of experimental results implies that slight over-parameterization (i.e., $C = {\rm {int}}(1.2P)$)could help the model better reconstruct all types of inputs. Here, we primarily compare the magnitudes of $P$ and $C$. Specifically, the scenario where the ratio $C/P>1$ is referred to as \textit {over-parameterized}, while the converse (i.e., $C/P<1$) is defined as \textit {under-parameterized}.}}{figure.caption.16}{}}
