\@writefile{lof}{\contentsline {figure}{\numberline {4.6}{\ignorespaces 测试欠参数化设置, 其中$C = {\rm  {int}}(0.8P)$. { 通过与\ref {fig-synthesized-experiment-results}比较, 这组实验结果表明, 轻微的过参数化 (即$C = {\rm  {int}}(1.2P)$) 可以帮助模型更好地重构所有类型的输入. 这里, 我们主要比较$P$和$C$的大小. 具体来说, 比率$C/P>1$的情况称为过参数化, 而相反的情况 (即$C/P<1$) 定义为欠参数化.} }}{55}{figure.caption.10}\protected@file@percent }
\newlabel{fig-synthesized-experiment-results-under-parameterized}{{4.6}{55}{测试欠参数化设置, 其中$C = {\rm {int}}(0.8P)$. { 通过与\ref {fig-synthesized-experiment-results}比较, 这组实验结果表明, 轻微的过参数化 (即$C = {\rm {int}}(1.2P)$) 可以帮助模型更好地重构所有类型的输入. 这里, 我们主要比较$P$和$C$的大小. 具体来说, 比率$C/P>1$的情况称为过参数化, 而相反的情况 (即$C/P<1$) 定义为欠参数化.}}{figure.caption.10}{}}
\newlabel{fig-NRP=0}{{4.7a}{55}{$c_4 = 0$}{figure.caption.11}{}}
\newlabel{sub@fig-NRP=0}{{a}{55}{$c_4 = 0$}{figure.caption.11}{}}
\newlabel{fig-NRP=0.2}{{4.7b}{55}{$c_4 = 0.2$}{figure.caption.11}{}}
\newlabel{sub@fig-NRP=0.2}{{b}{55}{$c_4 = 0.2$}{figure.caption.11}{}}
\newlabel{fig-NRP=0.4}{{4.7c}{55}{$c_4 = 0.4$}{figure.caption.11}{}}
\newlabel{sub@fig-NRP=0.4}{{c}{55}{$c_4 = 0.4$}{figure.caption.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.7}{\ignorespaces 测试不同数量的被替换补丁. { 参数$c_4$用于表征异常中被替换补丁的数量, 其中较大的$c_4$表示更多的被替换补丁. 当更多补丁被替换时, 正常数据和异常的重构误差之间的差距变得显著更大, 这与我们的分析一致.}}}{55}{figure.caption.11}\protected@file@percent }
\newlabel{fig-synthesized-experiment-results-NRP}{{4.7}{55}{测试不同数量的被替换补丁. { 参数$c_4$用于表征异常中被替换补丁的数量, 其中较大的$c_4$表示更多的被替换补丁. 当更多补丁被替换时, 正常数据和异常的重构误差之间的差距变得显著更大, 这与我们的分析一致.}}{figure.caption.11}{}}
