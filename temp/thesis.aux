\@writefile{lof}{\contentsline {figure}{\numberline {4.1}{\ignorespaces { \textbf  {Patches, features, and different types of anomalies}. As an illustrative example, consider the handwritten digits with only ``1'' being normal data. Patches $\bm  {x}$ are small parts of the images, e.g., those outlined with red boxes. $\bm  {x}_{a,1}$, $\bm  {x}_{a,2}$, $\bm  {x}_{b,1}$, and $\bm  {x}_{c,1}$ contain a \textbf  {normal feature} that captures the semantic information of ``1''. \ref {fig-sensory-patch} is called the non-semantic (or sensory) anomaly in the literature since $\bm  {x}_{b,2}$ contains \textbf  {non-feature noise}. $\bm  {x}_{c,2}$ contains an \textbf  {auxiliary feature} that does not capture the semantic information of ``1'', making \ref {fig-semantic-patch} a semantic anomaly. }}}{37}{figure.caption.11}\protected@file@percent }
\newlabel{fig-different-types-of-anomalies}{{4.1}{37}{ \textbf {Patches, features, and different types of anomalies}. As an illustrative example, consider the handwritten digits with only \qm {1} being normal data. Patches $\x $ are small parts of the images, e.g., those outlined with red boxes. $\x _{a,1}$, $\x _{a,2}$, $\x _{b,1}$, and $\x _{c,1}$ contain a \textbf {normal feature} that captures the semantic information of \qm {1}. \ref {fig-sensory-patch} is called the non-semantic (or sensory) anomaly in the literature since $\x _{b,2}$ contains \textbf {non-feature noise}. $\x _{c,2}$ contains an \textbf {auxiliary feature} that does not capture the semantic information of \qm {1}, making \ref {fig-semantic-patch} a semantic anomaly}{figure.caption.11}{}}
